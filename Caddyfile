{
  email {$ACME_EMAIL}
}

{$APP_DOMAIN} {
  encode gzip zstd

  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    X-Content-Type-Options "nosniff"
    Referrer-Policy "strict-origin-when-cross-origin"
    X-Frame-Options "DENY"
    Content-Security-Policy "default-src 'self'; img-src 'self' data: blob: https:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; font-src 'self' data: https:; connect-src 'self' https:; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
    Permissions-Policy "geolocation=(), microphone=(), camera=()"
  }

  @api path /api/* /uploads/*
  handle @api {
    reverse_proxy backend:8080
  }

  handle {
    reverse_proxy frontend:3000
  }
}
