POSTGRES_DB=catalogo_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password
JWT_SECRET=change-me-minimum-32-chars
JWT_EXPIRATION=86400000

NEXT_PUBLIC_API_URL=http://localhost:8080
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=Lax
APP_SECURITY_TRUST_PROXY_HEADERS=false
AUTH_LOGIN_STATE_TTL_SECONDS=86400
AUTH_LOGIN_MAX_TRACKED_KEYS=20000
AUTH_LOGIN_REDIS_ENABLED=false
AUTH_LOGIN_REDIS_KEY_PREFIX=auth:rl:

# Production reverse proxy
APP_DOMAIN=catalogo.seudominio.com
ACME_EMAIL=ops@seudominio.com

# Backend email verification / reset code delivery
APP_EMAIL_ENABLED=false
APP_EMAIL_FROM=no-reply@catalogo.local
SPRING_MAIL_HOST=
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
SPRING_MAIL_SMTP_AUTH=true
SPRING_MAIL_SMTP_STARTTLS_ENABLE=true
