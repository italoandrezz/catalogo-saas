SERVER_PORT=8080
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/catalogo_db
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=change-me-strong-password
SPRING_JPA_HIBERNATE_DDL_AUTO=validate
SPRING_JPA_SHOW_SQL=false
JWT_SECRET=change-me-minimum-32-chars
JWT_EXPIRATION=86400000
AUTH_COOKIE_NAME=catalog_auth_token
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=Lax
AUTH_LOGIN_MAX_ATTEMPTS=5
AUTH_LOGIN_LOCK_DURATION_SECONDS=900
AUTH_LOGIN_STATE_TTL_SECONDS=86400
AUTH_LOGIN_MAX_TRACKED_KEYS=20000
AUTH_LOGIN_REDIS_ENABLED=false
AUTH_LOGIN_REDIS_KEY_PREFIX=auth:rl:
APP_SECURITY_TRUST_PROXY_HEADERS=false
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
